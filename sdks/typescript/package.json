{
  "name": "@warrant/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Warrant cryptographic agent credential service",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["warrant", "jwt", "agent", "credentials", "delegation", "ai-safety"],
  "license": "Apache-2.0",
  "dependencies": {
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
