{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.chudah1/attest-mcp-server",
  "description": "A stdio MCP server that exposes Attest tools for credentials, approvals, audit trails, and evidence",
  "repository": {
    "url": "https://github.com/chudah1/attest-dev",
    "source": "github",
    "subfolder": "sdks/typescript/mcp-server"
  },
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@attest-dev/mcp-server",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ATTEST_API_KEY",
          "description": "Attest org API key",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "ATTEST_BASE_URL",
          "description": "Attest server URL (defaults to https://api.attestdev.com)",
          "isRequired": false,
          "isSecret": false,
          "format": "string"
        }
      ]
    }
  ]
}
